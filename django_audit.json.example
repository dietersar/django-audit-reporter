{
  "mail": {
    "to": "admin@example.com",
    "from_template": "django-audit@{hostname}",
    "subject_template": "[Django Audit] {hostname} - consolidated dependency overview",
    "smtp_host": "localhost",
    "smtp_port": 25
  },
  "reports": {
    "report_dir": "reports"
  },
  "python_release_catalog_url": "https://endoflife.date/api/python.json",
  "projects": [
    {
      "name": "project1",
      "dir": "project1_dir",
      "requirements": [
        "project1_dir/requirements.txt"
      ],
      "django_dir": "project1_dir_django"
    },
    {
      "name": "project2",
      "dir": "project2_dir",
      "requirements": [
        "project2_dir/requirements.txt",
        "project2_dir/requirements2.txt"
      ],
      "django_dir": "project2_dir_django",
      "frontend_dir": "project2_dir/frontend"
    }
  ]
}
